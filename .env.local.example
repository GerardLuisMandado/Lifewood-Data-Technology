# Local dev environment

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (frontend)
# Example: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url_here
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Admin emails allowed to access /dashboard (comma-separated)
VITE_ADMIN_EMAILS=your_email@yourdomain.com

# Admin bootstrap (server-side only; used by `node scripts/create-admin.mjs`)
# NOTE: Variables without the `VITE_` prefix are NOT exposed to the browser by Vite.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ADMIN_EMAIL=your_email@yourdomain.com
ADMIN_PASSWORD=your_strong_password_here
